APP_PASSCODE=change-me

# At least 32 random characters. Used only to sign session cookies.
SESSION_SECRET=replace-with-a-long-random-value

# Optional until Plaid and Claude integrations are enabled.
PLAID_CLIENT_ID=
PLAID_SECRET=
ANTHROPIC_API_KEY=
ENCRYPTION_KEY=
